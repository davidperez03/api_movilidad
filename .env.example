# ══════════════════════════════════════════════════════════════════════════════
#  TEMPLATE DE VARIABLES DE ENTORNO
#  Copiar a .env (dev) o inyectar como secrets en Vercel/Docker/K8s (prod).
#  Nunca commitear archivos con valores reales.
# ══════════════════════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────────────────────
APP_NAME=api-movilidad
# Valores válidos: development | staging | production
APP_ENV=development
# true solo en development — habilita SQL echo y stack traces completos
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Base de datos (Supabase / PostgreSQL) ─────────────────────────────────────
# Session Pooler — compatible con IPv4 y PgBouncer
# Formato: postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[ref]:[pass]@host:5432/postgres
# Direct connection — para migraciones Alembic (evita PgBouncer)
DATABASE_URL_DIRECT=postgresql://postgres.[ref]:[pass]@host:5432/postgres
# Docker/K8s: 20 | Vercel serverless: 1 (vercel.json lo sobreescribe automáticamente)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
# Recicla conexiones cada 30 min — compatible con PgBouncer
DATABASE_POOL_RECYCLE=1800
# Cancela queries que excedan este tiempo (ms)
DATABASE_STATEMENT_TIMEOUT_MS=30000

# ── Redis ─────────────────────────────────────────────────────────────────────
# Dev: redis://localhost:6379/0 | Prod: rediss://... (Upstash con TLS)
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=20
# TTL de la lista negra de tokens revocados (segundos) — debe >= JWT_ACCESS_TOKEN_EXPIRE_MINUTES*60
TOKEN_BLACKLIST_TTL=86400
# TTL del cache de permisos en Redis (segundos)
PERMISSIONS_CACHE_TTL=300
# TTL del cache de permisos en memoria por worker (segundos) — debe <= PERMISSIONS_CACHE_TTL
PERMISSIONS_LOCAL_CACHE_TTL=30
# Máximo de entradas en el cache en memoria por worker — controla uso de RAM
PERM_LOCAL_CACHE_MAX=1000
# TTL del cache de perfil de usuario en Redis (segundos)
# Durante este tiempo, cambios de nombre/estado pueden no reflejarse en requests activos
USUARIO_PERFIL_CACHE_TTL=60
# TTL de idempotency keys explícitas (Idempotency-Key header) en segundos
IDEMPOTENCY_TTL=86400
# Ventana anti doble-click automático (segundos) — sin header del cliente
IDEMPOTENCY_AUTO_TTL=10
# Timeout máximo de un request en vuelo antes de liberar el lock de idempotencia
IDEMPOTENCY_IN_FLIGHT_TTL=30
# Tamaño máximo de respuesta que se cachea para idempotencia (KB)
IDEMPOTENCY_MAX_BODY_CACHE_KB=100

# ── JWT / Sesiones ────────────────────────────────────────────────────────────
# Genera con: openssl rand -hex 32
JWT_SECRET_KEY=CAMBIA-ESTO-genera-con-openssl-rand-hex-32
JWT_ALGORITHM=HS256
# Tiempo de vida del access token (minutos) — corto por seguridad
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Tiempo de vida del refresh token (días)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# Minutos de inactividad antes de cerrar la sesión automáticamente
INACTIVIDAD_TIMEOUT_MINUTOS=30

# ── HMAC — firma service-to-service ───────────────────────────────────────────
# Genera con: openssl rand -hex 32
HMAC_SIGNING_SECRET=CAMBIA-ESTO-genera-con-openssl-rand-hex-32
# Ventana anti-replay en segundos (±). Requests con timestamp fuera de esta ventana se rechazan.
HMAC_REPLAY_WINDOW_SECONDS=300

# ── Seguridad HTTP ────────────────────────────────────────────────────────────
# BCRYPT_ROUNDS: rango válido 10–14. Dev: 10 (rápido). Prod: 12 (recomendado).
BCRYPT_ROUNDS=12
# Rate limit global por IP (requests por minuto)
RATE_LIMIT_PER_MINUTE=60
# Rate limit específico para endpoints de autenticación (requests por minuto por email+IP)
RATE_LIMIT_AUTH_PER_MINUTE=10
# Orígenes permitidos para CORS. Vacío = deniega todo. Prod: solo tu dominio.
CORS_ORIGINS=["https://tuapp.com"]
# Hosts permitidos. Prod: nunca usar "*".
ALLOWED_HOSTS=["tuapp.com","api.tuapp.com"]

# ── Login — política de bloqueo ───────────────────────────────────────────────
# Son dos capas independientes con ventanas distintas:
#   1. RATE_LIMIT_AUTH_PER_MINUTE → frena ataques rápidos por IP (ventana 1 minuto)
#   2. LOGIN_LOCKOUT             → acumula intentos lentos o desde múltiples IPs (ventana LOGIN_LOCKOUT_TTL)
#
# LOGIN_LOCKOUT_MAX_INTENTOS debe ser mayor que RATE_LIMIT_AUTH_PER_MINUTE.
# Si son iguales, el rate limiter siempre actúa primero y el lockout nunca se activa.
LOGIN_LOCKOUT_MAX_INTENTOS=10
# Duración del bloqueo en segundos (900 = 15 minutos)
LOGIN_LOCKOUT_TTL=900
# Tiempo mínimo de respuesta del endpoint de login (segundos) — previene enumeración de cuentas por timing
# No bajar de 0.20 en producción
LOGIN_MIN_RESPONSE_SECS=0.30

# ── API Keys ──────────────────────────────────────────────────────────────────
# Cada cuántos segundos se actualiza el campo ultimo_uso en BD al usar una API Key
# Valor alto = menos escrituras. Valor bajo = auditoría más precisa.
API_KEY_USO_THROTTLE_SECONDS=60

# ── Observabilidad ────────────────────────────────────────────────────────────
# Si está vacío → /metrics es público (solo aceptable en dev).
# En producción: genera con openssl rand -hex 16. Acceso: GET /metrics?token=<valor>
METRICS_SECRET=

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
# true  → filtra todos los endpoints por organization_id del JWT + aplica RLS
# false → modo single-tenant (sin filtro por organización)
MULTITENANCY_ENABLED=false

# ── Auditoría ─────────────────────────────────────────────────────────────────
# true  → registra todas las operaciones de escritura (POST/PATCH/PUT/DELETE)
AUDIT_ENABLED=true
# Paths que NO se auditan (health checks, docs, métricas)
AUDIT_EXCLUDE_PATHS=["/health","/ready","/docs","/redoc","/openapi.json","/metrics"]

# ── Paginación ────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── Límites de requests ───────────────────────────────────────────────────────
# Tamaño máximo del body en bytes (10485760 = 10 MB)
MAX_REQUEST_BODY_SIZE=10485760

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
# Gmail: habilitar "Contraseñas de aplicación" en seguridad de la cuenta Google (16 chars)
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=tu-correo@gmail.com
SMTP_TLS=true
# TTL del token de verificación de email (segundos) — 86400 = 24 horas
EMAIL_VERIFICATION_TTL=86400
# TTL del token de reset de password (segundos) — 3600 = 1 hora
PASSWORD_RESET_TTL=3600
# Segundos mínimos entre reenvíos del mismo email (verificación y reset)
EMAIL_REENVIO_RATE_TTL=300

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL base del frontend — aparece en los links de los emails. DEBE ser HTTPS en producción.
FRONTEND_URL=https://tuapp.com
